{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "server.js",  "use": "@vercel/node"   }
  ],
  "routes": [
    { "src": "/css/(.*)",     "dest": "/public/css/$1"     },
    { "src": "/js/(.*)",      "dest": "/public/js/$1"      },
    { "src": "/assets/(.*)",  "dest": "/public/assets/$1"  },
    { "src": "/presets/(.*)", "dest": "/public/presets/$1" },
    { "src": "/(.*)",         "dest": "/server.js"          }
  ]
}
